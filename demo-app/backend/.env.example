# Demo backend env. The provider is LOCKED to OpenRouter and the models are FIXED in
# code (a strong host model + an economical leaf model); there is no user model config.
#
# Two ways to go online, both with ONE OpenRouter key:
#   1. Per session (headline path): the frontend sends the user's key on the run config
#      as configurable.openrouter_api_key — nothing to set here.
#   2. Local / operator mode: set OPENROUTER_API_KEY below; every session uses it.
#
# With no key from either source the host runs in offline demo mode (a deterministic
# scripted host) so `langgraph dev` still boots and the Gen-UI round-trip is demonstrable
# without credentials.

# OPENROUTER_API_KEY=sk-or-...

# Optional internal escape hatch (NOT the headline path): pin a different model id for a
# local experiment. The default is the fixed HOST_MODEL / LEAF_MODEL constants in
# _models.py — leave these unset to use them.
# LDW_DEMO_HOST_MODEL=anthropic/claude-opus-4.8
# LDW_DEMO_LEAF_MODEL=anthropic/claude-sonnet-4.6
