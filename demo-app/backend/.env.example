# Copy to .env to run the host against a real model (BYO-key).
# With no key set, the host runs in offline demo mode (deterministic scripted host)
# so `langgraph dev` still boots and the Gen-UI round-trip is demonstrable.

# Option A: OpenAI directly.
# OPENAI_API_KEY=sk-...

# Option B: OpenRouter (host model defaults to openai/gpt-4o-mini; override below).
# OPENROUTER_API_KEY=sk-or-...
# LDW_DEMO_HOST_MODEL=openai/gpt-4o-mini
